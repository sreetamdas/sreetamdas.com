VITE_SITE_URL="http://localhost:3000"
DEBUG_MODE=

BUTTONDOWN_API_KEY=

# For /keebs
IMGUR_API_CLIENT_ID=
IMGUR_KEEBS_ALBUM_HASH=
NOTION_TOKEN=
NOTION_KEEBS_PAGE_ID=

GITHUB_TOKEN=
GITHUB_RWC_GIST_ID=

# Plausible Stats API for /stats
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID="sreetamdas.com"

# Optional public build-time fallback for the non-secret RWC gist id.
# Prefer GITHUB_RWC_GIST_ID unless you intentionally need this exposed to Vite.
VITE_GITHUB_RWC_GIST_ID=

# Sentry
VITE_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cloudflare
CF_ACCOUNT_ID=
CF_D1_DB_ID=
CF_D1_TOKEN=

# CI/Cloudflare Workers Builds tip for TanStack Start prerendering:
# - set CLOUDFLARE_INCLUDE_PROCESS_ENV=true in the build environment
# - keep API keys and tokens server-only; do not add VITE_ prefixes to secrets
# - if you prefer reference-based env loading in CI, use a committed `.env` file like:
#   BUTTONDOWN_API_KEY=${BUTTONDOWN_API_KEY}
#   NOTION_TOKEN=${NOTION_TOKEN}
#   NOTION_KEEBS_PAGE_ID=${NOTION_KEEBS_PAGE_ID}
#   IMGUR_API_CLIENT_ID=${IMGUR_API_CLIENT_ID}
#   IMGUR_KEEBS_ALBUM_HASH=${IMGUR_KEEBS_ALBUM_HASH}
#   GITHUB_RWC_GIST_ID=${GITHUB_RWC_GIST_ID}
#   GITHUB_TOKEN=${GITHUB_TOKEN}
