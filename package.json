{
	"name": "sreetamdas.com",
	"version": "5.0.0",
	"license": "MIT",
	"type": "module",
	"browser": {
		"fs": false
	},
	"scripts": {
		"build:content-collections": "content-collections build",
		"generate-feeds": "tsx scripts/generate-feeds.ts",
		"dev": "vp dev",
		"prebuild": "vp run build:content-collections && vp run generate-feeds && node scripts/generate-build-info.mjs",
		"build": "vp build",
		"preview": "vp preview",
		"test:unit": "pnpm exec vp test run --config vitest.unit.config.ts",
		"test:workers": "pnpm exec vp test run --config vitest.config.ts",
		"test:workers:watch": "pnpm exec vp test --config vitest.config.ts",
		"test:workers:serial": "pnpm exec vp test run --config vitest.config.ts --max-workers=1 --no-isolate",
		"test:workers:debug": "pnpm exec vp test --config vitest.config.ts --inspect --no-file-parallelism",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui",
		"compile": "tsc --watch",
		"pretypecheck": "vp run build:content-collections",
		"typecheck": "tsgo -p tsconfig.json --noEmit",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./src/cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:bootstrap:local": "wrangler d1 execute sreetamdas_com --local --command \"SELECT 1\"",
		"db:migrate:local": "vp db:bootstrap:local && drizzle-kit migrate --config drizzle.studio.local.config.ts",
		"db:migrate:remote": "drizzle-kit migrate --config drizzle.studio.remote.config.ts",
		"db:studio": "drizzle-kit studio --config drizzle.studio.local.config.ts",
		"db:studio:local": "vp db:bootstrap:local && drizzle-kit studio --config drizzle.studio.local.config.ts",
		"db:studio:remote": "drizzle-kit studio --config drizzle.studio.remote.config.ts",
		"oxlint:check": "vp lint ./src",
		"oxlint:fix": "vp lint --fix ./src",
		"oxfmt:check": "vp fmt --check ./src '!**/routeTree.gen.ts'",
		"oxfmt:write": "vp fmt --write ./src '!**/routeTree.gen.ts'",
		"lint": "vp run oxfmt:check && vp run oxlint:check",
		"lint:fix": "vp run oxfmt:write && vp run oxlint:fix",
		"format": "vp run oxfmt:write",
		"deploy": "CLOUDFLARE_ENV=production pnpm build && CLOUDFLARE_ENV=production wrangler deploy -e production",
		"deploy:production": "CLOUDFLARE_ENV=production pnpm build && CLOUDFLARE_ENV=production wrangler deploy -e production",
		"deploy:staging": "CLOUDFLARE_ENV=staging pnpm build && CLOUDFLARE_ENV=staging wrangler deploy -e staging",
		"deploy:preview": "node scripts/deploy-preview.mjs",
		"prepare": "vp config",
		"lint-staged": "vp staged"
	},
	"dependencies": {
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/inter": "^5.2.8",
		"@notionhq/client": "^5.22.0",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@remoteoss/json-schema-form": "^1.2.12",
		"@sentry/cloudflare": "^10.54.0",
		"@sentry/tanstackstart-react": "^10.54.0",
		"@shikijs/colorized-brackets": "^4.1.0",
		"@shikijs/langs-precompiled": "^4.1.0",
		"@sreetamdas/karma": "^3.1.1",
		"@tanstack/hotkeys": "^0.8.0",
		"@tanstack/react-query": "^5.100.14",
		"@tanstack/react-query-devtools": "^5.100.14",
		"@tanstack/react-router": "^1.170.8",
		"@tanstack/react-start": "^1.168.14",
		"@tanstack/start-static-server-functions": "^1.167.9",
		"clsx": "^2.1.1",
		"drizzle-orm": "1.0.0-beta.15-859cf75",
		"image-size": "^2.0.2",
		"lodash-es": "^4.18.1",
		"modern-monaco": "^0.4.1",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-icons": "^5.6.0",
		"react-svg-worldmap": "^2.0.2",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-toc": "^9.0.0",
		"safe-mdx": "^1.11.1",
		"shiki": "^4.1.0",
		"shiki-magic-move": "^1.3.2",
		"tailwind-merge": "^3.6.0",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.39.0",
		"@cloudflare/vitest-pool-workers": "^0.16.10",
		"@content-collections/cli": "^0.1.9",
		"@content-collections/core": "^0.15.1",
		"@content-collections/vite": "^0.3.0",
		"@octokit/types": "^16.0.0",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/lodash-es": "^4.17.12",
		"@types/mdx": "^2.0.13",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@types/unist": "~3.0.3",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitejs/plugin-rsc": "^0.5.26",
		"better-sqlite3": "^12.10.0",
		"drizzle-kit": "1.0.0-beta.15-859cf75",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite-plus": "catalog:",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest",
		"wrangler": "^4.95.0"
	},
	"engines": {
		"node": "24"
	},
	"packageManager": "pnpm@11.3.0",
	"msw": {
		"workerDirectory": "public"
	}
}
