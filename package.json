{
	"name": "sreetamdas.com",
	"version": "5.0.0",
	"license": "MIT",
	"type": "module",
	"browser": {
		"fs": false
	},
	"scripts": {
		"dev:content": "velite --config './.config/velite.config.ts' --watch",
		"build:content": "velite --config './.config/velite.config.ts' --clean",
		"generate-feeds": "tsx scripts/generate-feeds.ts",
		"dev": "pnpm run dev:content & vp dev",
		"prebuild": "pnpm run build:content && pnpm run generate-feeds",
		"build": "vp build",
		"preview": "vp preview",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui",
		"compile": "tsc --watch",
		"pretypecheck": "pnpm run build:content",
		"typecheck": "tsgo -p tsconfig.json --noEmit",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./src/cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:bootstrap:local": "wrangler d1 execute sreetamdas_com --local --command \"SELECT 1\"",
		"db:migrate:local": "pnpm db:bootstrap:local && drizzle-kit migrate --config drizzle.studio.local.config.ts",
		"db:migrate:remote": "drizzle-kit migrate --config drizzle.studio.remote.config.ts",
		"db:studio": "drizzle-kit studio --config drizzle.studio.local.config.ts",
		"db:studio:local": "pnpm db:bootstrap:local && drizzle-kit studio --config drizzle.studio.local.config.ts",
		"db:studio:remote": "drizzle-kit studio --config drizzle.studio.remote.config.ts",
		"oxlint:check": "vp lint ./src",
		"oxlint:fix": "vp lint --fix ./src",
		"oxfmt:check": "vp fmt --check ./src '!**/routeTree.gen.ts'",
		"oxfmt:write": "vp fmt --write ./src '!**/routeTree.gen.ts'",
		"lint": "pnpm run oxfmt:check && pnpm run oxlint:check",
		"lint:fix": "pnpm run oxfmt:write && pnpm run oxlint:fix",
		"format": "pnpm run oxfmt:write",
		"deploy": "wrangler deploy -e production",
		"deploy:production": "wrangler deploy -e production",
		"deploy:staging": "wrangler deploy -e staging",
		"prepare": "vp config",
		"lint-staged": "vp staged"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.36.3",
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/inter": "^5.2.8",
		"@notionhq/client": "^5.20.0",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@sentry/cloudflare": "^10.52.0",
		"@sentry/tanstackstart-react": "^10.52.0",
		"@shikijs/colorized-brackets": "^4.0.2",
		"@shikijs/langs-precompiled": "^4.0.2",
		"@sreetamdas/karma": "^3.1.1",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/hotkeys": "^0.8.0",
		"@tanstack/react-query": "^5.100.9",
		"@tanstack/react-query-devtools": "^5.100.9",
		"@tanstack/react-router": "^1.169.2",
		"@tanstack/react-start": "^1.167.65",
		"@tanstack/start-static-server-functions": "^1.166.41",
		"clsx": "^2.1.1",
		"drizzle-orm": "1.0.0-beta.15-859cf75",
		"image-size": "^2.0.2",
		"lodash-es": "^4.18.1",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-icons": "^5.6.0",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-toc": "^9.0.0",
		"safe-mdx": "^1.11.0",
		"shiki": "^4.0.2",
		"shiki-magic-move": "^1.3.0",
		"tailwind-merge": "^3.5.0",
		"unist-util-visit": "^5.0.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@octokit/types": "^16.0.0",
		"@playwright/test": "^1.59.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/lodash-es": "^4.17.12",
		"@types/mdx": "^2.0.13",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/unist": "~3.0.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitejs/plugin-rsc": "^0.5.26",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "1.0.0-beta.15-859cf75",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"velite": "^0.3.1",
		"vite-plus": "catalog:",
		"wrangler": "^4.90.0"
	},
	"engines": {
		"node": "24"
	},
	"packageManager": "pnpm@11.0.9",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@tailwindcss/oxide",
			"better-sqlite3",
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"msw": {
		"workerDirectory": "public"
	}
}
