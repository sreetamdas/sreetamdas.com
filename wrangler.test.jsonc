{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sreetamdas-com-tests",
	"main": "./src/testing/worker-test-entry.ts",
	"compatibility_date": "2026-05-10",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "SITE_PRESENCE",
				"class_name": "PresenceDurableObject"
			},
			{
				"name": "SLIDE_SESSIONS",
				"class_name": "SlideSessionDurableObject"
			}
		]
	},
	"migrations": [
		{
			"tag": "do-v1",
			"new_sqlite_classes": ["PresenceDurableObject"]
		},
		{
			"tag": "do-v2-slide-sessions",
			"new_sqlite_classes": ["SlideSessionDurableObject"]
		}
	]
}
